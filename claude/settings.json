{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run check:*)",
      "Bash(gh run view:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(shred:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "mcp__supabase__execute_sql"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr review:*)",
      "Bash(rm:*)",
      "Bash(mv:*)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay $DOTFILES_DIR/assets/notification.mp3 2> /dev/null"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay $DOTFILES_DIR/assets/stop.mp3 2> /dev/null"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$DOTFILES_DIR/claude/statusline.js"
  },
  "enabledPlugins": {
    "joy-docs@joy-plugins": true,
    "joy-git@joy-plugins": true,
    "joy-claude@joy-plugins": true
  },
  "extraKnownMarketplaces": {
    "joy-plugins": {
      "source": {
        "source": "directory",
        "path": "$DOTFILES_DIR/claude-marketplace"
      }
    }
  },
  "language": "日本語",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
